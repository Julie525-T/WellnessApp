<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HealthyRecipes">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Healthy Recipes"
        android:textSize="30dp"
        android:layout_marginTop="30dp"
        android:textAlignment="center"
        android:textColor="#3DBBF6"
        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:src="@drawable/image5"
        android:layout_margin="20dp"
        android:scaleType="centerCrop"
        />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:id="@+id/recipeListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🥗 Avocado Salad"
                android:textSize="18sp"
                android:padding="10dp"
                android:textColor="#3DBBF6"/>

            <Button
                android:id="@+id/btnBananaSmoothie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="See Details"
                android:layout_margin="10dp"
                android:backgroundTint="#3DBBF6"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🍲 Quinoa Soup"
                android:textSize="18sp"
                android:padding="10dp"
                android:textColor="#3DBBF6"/>
            <Button
                android:id="@+id/btnBananaSmoothie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="See Details"
                android:layout_margin="10dp"
                android:backgroundTint="#3DBBF6"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🍌 Banana Smoothie"
                android:textSize="18sp"
                android:padding="10dp"
                android:textColor="#3DBBF6"/>
            <Button
                android:id="@+id/btnBananaSmoothie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="See Details"
                android:layout_margin="10dp"
                android:backgroundTint="#3DBBF6"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
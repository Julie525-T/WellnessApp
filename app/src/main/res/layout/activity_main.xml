<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">




        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health and Wellness App"
            android:textColor="#3DBBF6"
            android:fontFamily="sans-serif-condensed-light"
            android:textSize="40sp"
            android:layout_marginTop="30dp"
            android:textAlignment="center"

            />

        <ImageView
            android:id="@+id/image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:scaleType="centerCrop"
            android:src="@drawable/image2"
            android:padding="20dp"


            />

        <Button
            android:id="@+id/recipes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:backgroundTint="#3DBBF6"
            android:text="Healthy Recipes"
            android:textSize="30sp"

            />

        <Button
            android:id="@+id/nutrition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:textSize="30sp"
            android:backgroundTint="#3DBBF6"
            android:text="Nutrition Advice"
            />

        <Button
            android:id="@+id/meditation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:backgroundTint="#3DBBF6"
            android:text="Meditation"
            android:textSize="30sp"
            />


        <Button
            android:id="@+id/hydration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:textSize="30sp"
            android:backgroundTint="#3DBBF6"
            android:text="Hydration Alert"
            />

        <Button
            android:id="@+id/exercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:textSize="30sp"
            android:backgroundTint="#3DBBF6"
            android:text="Start Exercise"
            />


        <Button
            android:id="@+id/motivation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:textSize="30sp"
            android:backgroundTint="#3DBBF6"
            android:text="Daily Motivation"
            />

        <Button
            android:id="@+id/goals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:textSize="30sp"
            android:backgroundTint="#3DBBF6"
            android:text="Weekly Goals"
            />

        <Button
            android:id="@+id/progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:textSize="30sp"
            android:backgroundTint="#3DBBF6"
            android:text="Check Progress"/>









    </LinearLayout>


</ScrollView>
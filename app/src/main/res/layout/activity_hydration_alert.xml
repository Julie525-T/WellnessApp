<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HydrationAlert">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hydration Alert"
        android:textColor="#3DBBF6"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="400dp"
        android:src="@drawable/image2"
        android:scaleType="centerCrop"
        android:layout_margin="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Today's Water Intake"
        android:textSize="18sp"
        android:textColor="#3DBBF6"
        android:layout_marginTop="20dp"/>

    <ProgressBar
        android:layout_width="match_parent"
        android:layout_height="10dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:progress="70"
        android:progressTint="#3DBBF6"
        android:layout_margin="10dp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Click the button below to log a glass of water 💧"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"/>

    <Button
        android:id="@+id/btnAddWater"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Glass of Water"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:layout_margin="10dp"
        android:backgroundTint="#3DBBF6"
        android:textColor="#FFFFFF"/>

</LinearLayout>